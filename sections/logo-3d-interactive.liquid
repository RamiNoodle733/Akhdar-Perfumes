{% comment %}
  3D Interactive Logo Section
  Displays a GLB 3D model that users can interact with
{% endcomment %}

{{ 'logo-3d-viewer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding isolate">
    <div class="page-width">
      {% if section.settings.heading != blank %}
        <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin">
          <h2 class="title {{ section.settings.heading_size }} color-{{ section.settings.color_scheme }}">
            {{ section.settings.heading }}
          </h2>
        </div>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="rich-text color-{{ section.settings.color_scheme }}">
          <div class="rich-text__wrapper rte">
            {{ section.settings.description }}
          </div>
        </div>
      {% endif %}

      <div class="logo-3d-container" data-section-id="{{ section.id }}">
        {% if section.settings.glb_file_url != blank %}
          <div 
            id="logo-3d-viewer-{{ section.id }}" 
            class="logo-3d-viewer"
            data-glb-url="{{ section.settings.glb_file_url }}"
            data-auto-rotate="{{ section.settings.auto_rotate }}"
            data-enable-zoom="{{ section.settings.enable_zoom }}"
            data-background-color="{{ section.settings.background_color }}"
            style="width: 100%; height: {{ section.settings.viewer_height }}px; border-radius: {{ section.settings.border_radius }}px;"
          >
            <div class="logo-3d-loading">
              <div class="loading-spinner"></div>
              <p>Loading 3D Logo...</p>
            </div>
          </div>
          
          {% if section.settings.show_controls %}
            <div class="logo-3d-controls">
              <button class="logo-3d-control" id="reset-camera-{{ section.id }}">Reset View</button>
              {% if section.settings.auto_rotate %}
                <button class="logo-3d-control" id="toggle-rotation-{{ section.id }}">Pause Rotation</button>
              {% endif %}
            </div>
          {% endif %}

          {% if section.settings.show_instructions %}
            <div class="logo-3d-instructions">
              <p>{{ section.settings.instructions_text | default: "Click and drag to rotate • Scroll to zoom • Touch to interact on mobile" }}</p>
            </div>
          {% endif %}
        {% else %}
          <div class="logo-3d-placeholder">
            <svg width="100" height="100" viewBox="0 0 100 100" fill="currentColor">
              <rect x="10" y="20" width="80" height="60" rx="5" fill="none" stroke="currentColor" stroke-width="2"/>
              <circle cx="30" cy="40" r="5" fill="currentColor"/>
              <circle cx="70" cy="40" r="5" fill="currentColor"/>
              <path d="M25 60 Q50 75 75 60" stroke="currentColor" stroke-width="2" fill="none"/>
            </svg>
            <p>Upload your GLB file in the section settings</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  // Debug information
  console.log('3D Logo Section loaded');
  console.log('GLB URL:', '{{ section.settings.glb_file_url }}');
</script>
<script src="{{ 'logo-3d-viewer.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "3D Interactive Logo",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Our 3D Logo",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "3D Model Settings"
    },
    {
      "type": "url",
      "id": "glb_file_url",
      "label": "GLB File URL",
      "info": "Upload your GLB file to Files in Shopify admin, then copy the URL here"
    },
    {
      "type": "range",
      "id": "viewer_height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "3D Viewer Height",
      "default": 400
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Corner Radius",
      "default": 10
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Interaction Settings"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "default": true,
      "label": "Auto Rotate"
    },
    {
      "type": "checkbox",
      "id": "enable_zoom",
      "default": true,
      "label": "Enable Zoom"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "default": true,
      "label": "Show Control Buttons"
    },
    {
      "type": "checkbox",
      "id": "show_instructions",
      "default": true,
      "label": "Show Instructions"
    },
    {
      "type": "text",
      "id": "instructions_text",
      "label": "Instructions Text",
      "default": "Click and drag to rotate • Scroll to zoom • Touch to interact on mobile"
    },
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "Accent 1"
        },
        {
          "value": "accent-2",
          "label": "Accent 2"
        },
        {
          "value": "background-1",
          "label": "Background 1"
        },
        {
          "value": "background-2",
          "label": "Background 2"
        },
        {
          "value": "inverse",
          "label": "Inverse"
        }
      ],
      "default": "background-1",
      "label": "Color Scheme"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "3D Interactive Logo"
    }
  ]
}
{% endschema %}