; fill:currentColor; }\n  .akhdar-btn .label{ letter-spacing:.15px; }\n  \/* Bigger hit area on mobile + icon-only to save space *\/\n  @media (max-width: 990px){\n    .akhdar-btn{ padding:.55rem .6rem; }\n    .akhdar-btn .label{ display:none; }\n    .akhdar-btn svg{ width:26px; height:26px; }\n  }\n\n  \/* Optional: gentle “notice me” pulse on first load *\/\n  @keyframes akPulse{ 0%{box-shadow:0 0 0 0 rgba(211,174,57,.35)} 70%{box-shadow:0 0 0 10px rgba(211,174,57,0)} 100%{box-shadow:0 0 0 0 rgba(211,174,57,0)} }\n  .akhdar-btn.pulse{ animation: akPulse 2.2s ease 1; }\n\n  \/* Color accents per network (tweak if needed) *\/\n  .akhdar-btn.insta{ color: var(--ak-gold); }\n  .akhdar-btn.linkedin{ color: #ADD58A; } \/* light green accent *\/\n  .akhdar-btn.facebook{ color: var(--ak-teal); }\n  .akhdar-btn.tiktok{ color: var(--ak-gold); }\n<\/style>\n\n<div class=\"akhdar-header-socials\" role=\"navigation\" aria-label=\"Social links\">\n  <!-- Instagram (bold camera glyph) -->\n  <a class=\"akhdar-btn insta pulse\" href=\"https:\/\/www.instagram.com\/akhdar_perfumes\" target=\"_blank\" rel=\"noopener\" aria-label=\"Instagram\">\n    <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n      <rect x=\"3\" y=\"4\" width=\"18\" height=\"17\" rx=\"4\" ry=\"4\" stroke=\"currentColor\" stroke-width=\"2\" fill=\"none\"\/>\n      <circle cx=\"12\" cy=\"12.5\" r=\"4\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"\/>\n      <circle cx=\"17.5\" cy=\"8.5\" r=\"1.2\"\/>\n    <\/svg>\n    <span class=\"label\">Instagram<\/span>\n  <\/a>\n\n  <!-- LinkedIn (clean “in” mark) -->\n  <a class=\"akhdar-btn linkedin\" href=\"https:\/\/linkedin.com\/company\/akhdar-perfumes\" target=\"_blank\" rel=\"noopener\" aria-label=\"LinkedIn\">\n    <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n      <rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"3\" ry=\"3\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"\/>\n      <circle cx=\"8\" cy=\"10\" r=\"1.2\"\/>\n      <path d=\"M7 16.5v-4.2h2.1v4.2H7zm5.1 0v-2.7c0-.9.73-1.6 1.63-1.6s1.57.7 1.57 1.6v2.7h2.1v-3.1c0-2-1.31-3.5-3.16-3.5-1.01 0-1.86.43-2.14 1.11v-1.01H9.9v6.5h2.2z\"\/>\n    <\/svg>\n    <span class=\"label\">LinkedIn<\/span>\n  <\/a>\n\n  <!-- Facebook (rounded square + \"f\") -->\n  <a class=\"akhdar-btn facebook\" href=\"https:\/\/www.facebook.com\/akhdarperfumes\" target=\"_blank\" rel=\"noopener\" aria-label=\"Facebook\">\n    <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n      <rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"3\" ry=\"3\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"\/>\n      <path d=\"M13 10.5h2V8.5h-2c-1.4 0-2.5 1.1-2.5 2.5v1.5H8.8v2H10.5v3h2v-3h2l.4-2H12v-1.5c0-.5.4-1 1-1z\"\/>\n    <\/svg>\n    <span class=\"label\">Facebook<\/span>\n  <\/a>\n\n  <!-- TikTok (musical note) -->\n  <a class=\"akhdar-btn tiktok\" href=\"https:\/\/www.tiktok.com\/@akhdar_perfumes\" target=\"_blank\" rel=\"noopener\" aria-label=\"TikTok\">\n    <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n      <path d=\"M14 6.5v6.1a4.1 4.1 0 1 1-2.2-3.6v2.2a2 2 0 1 0 1 1.8V5.5h1.2c.7 1.1 2 2.1 4 2.3v2.1c-1.9-.1-3.3-.8-4.2-1.6z\" \/>\n      <circle cx=\"9\" cy=\"15.8\" r=\"0\" \/>\n    <\/svg>\n    <span class=\"label\">TikTok<\/span>\n  <\/a>\n<\/div>","color_scheme":"scheme-5","section_width":"page-width","padding-block-start":10,"padding-block-end":10}}},"order":["header_section","header_announcements_Aiqtym","header_announcements_pFTmPF","custom_liquid_YgMbLh"]}