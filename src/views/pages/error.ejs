<div class="bg-white min-h-screen flex items-center justify-center">
  <div class="container mx-auto px-4 py-20 text-center">
    <div class="max-w-md mx-auto">
      <div class="w-20 h-20 mx-auto bg-red-100 rounded-full flex items-center justify-center">
        <svg class="w-10 h-10 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
      </div>
      
      <h1 class="mt-6 text-2xl font-semibold text-gray-900">Something Went Wrong</h1>
      <p class="mt-4 text-gray-600">
        We're sorry, but something unexpected happened. Please try again later.
      </p>
      
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mt-6 p-4 bg-gray-100 rounded-lg text-left">
          <p class="text-sm font-mono text-red-600"><%= typeof error === 'string' ? error : (error.message || 'Unknown error') %></p>
        </div>
      <% } %>
      
      <div class="mt-8 space-y-4">
        <a href="/" class="block w-full py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-medium rounded-md transition-colors">
          Go Home
        </a>
        <button 
          type="button"
          onclick="window.history.back()"
          class="block w-full py-3 border border-gray-300 hover:border-gray-400 text-gray-700 font-medium rounded-md transition-colors"
        >
          Go Back
        </button>
      </div>
      
      <p class="mt-8 text-sm text-gray-500">
        Need help? <a href="/pages/contact" class="text-emerald-600 hover:text-emerald-700">Contact us</a>
      </p>
    </div>
  </div>
</div>
