<div class="mb-8">
  <a href="/admin/collections" class="text-sm text-emerald-600 hover:text-emerald-700 flex items-center gap-1 mb-4">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Collections
  </a>
  <h1 class="text-2xl font-semibold text-gray-900"><%= collection ? 'Edit Collection' : 'Add Collection' %></h1>
</div>

<form 
  action="<%= collection ? '/admin/collections/' + collection._id : '/admin/collections' %>" 
  method="POST"
  enctype="multipart/form-data"
  class="max-w-2xl space-y-6"
>
  <% if (collection) { %>
    <input type="hidden" name="_method" value="PUT">
  <% } %>
  
  <div class="bg-white rounded-lg shadow-sm p-6 space-y-4">
    <div>
      <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Title</label>
      <input type="text" id="title" name="title" value="<%= collection ? collection.title : '' %>" required class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500">
    </div>
    
    <div>
      <label for="handle" class="block text-sm font-medium text-gray-700 mb-1">Handle (URL)</label>
      <input type="text" id="handle" name="handle" value="<%= collection ? collection.handle : '' %>" placeholder="auto-generated-from-title" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500">
    </div>
    
    <div>
      <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Description</label>
      <textarea id="description" name="description" rows="4" class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"><%= collection ? collection.description || '' : '' %></textarea>
    </div>
    
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Collection Image</label>
      <% if (collection && collection.image && collection.image.url) { %>
        <div class="mb-3">
          <img src="<%= collection.image.url %>" alt="<%= collection.title %>" class="w-32 h-32 object-cover rounded-md">
        </div>
      <% } %>
      <input type="file" name="image" accept="image/*" class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100">
    </div>
    
    <div>
      <label class="flex items-center gap-2">
        <input type="checkbox" name="published" <%= (!collection || collection.published) ? 'checked' : '' %> class="rounded text-emerald-600 focus:ring-emerald-500">
        <span class="text-sm text-gray-700">Published</span>
      </label>
    </div>
  </div>
  
  <div class="flex items-center justify-end gap-4">
    <a href="/admin/collections" class="px-6 py-2 border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">Cancel</a>
    <button type="submit" class="px-6 py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-medium rounded-md transition-colors">
      <%= collection ? 'Save Changes' : 'Create Collection' %>
    </button>
  </div>
</form>
