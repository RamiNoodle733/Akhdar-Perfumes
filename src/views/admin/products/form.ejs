<div class="mb-8">
  <a href="/admin/products" class="text-sm text-emerald-600 hover:text-emerald-700 flex items-center gap-1 mb-4">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    Back to Products
  </a>
  <h1 class="text-2xl font-semibold text-gray-900"><%= product ? 'Edit Product' : 'Add Product' %></h1>
</div>

<form 
  action="<%= product ? `/admin/products/${product._id}` : '/admin/products' %>" 
  method="POST"
  enctype="multipart/form-data"
  class="space-y-8"
>
  <% if (product) { %>
    <input type="hidden" name="_method" value="PUT">
  <% } %>
  
  <div class="grid lg:grid-cols-3 gap-8">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Basic Info -->
      <div class="bg-white rounded-lg shadow-sm p-6 space-y-4">
        <div>
          <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Title</label>
          <input 
            type="text" 
            id="title" 
            name="title" 
            value="<%= product ? product.title : '' %>"
            required
            class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
          >
        </div>
        
        <div>
          <label for="handle" class="block text-sm font-medium text-gray-700 mb-1">Handle (URL)</label>
          <input 
            type="text" 
            id="handle" 
            name="handle" 
            value="<%= product ? product.handle : '' %>"
            placeholder="auto-generated-from-title"
            class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
          >
        </div>
        
        <div>
          <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <textarea 
            id="description" 
            name="description" 
            rows="6"
            class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
          ><%= product ? product.description : '' %></textarea>
        </div>
      </div>
      
      <!-- Fragrance Notes -->
      <div class="bg-white rounded-lg shadow-sm p-6 space-y-4">
        <h3 class="font-medium text-gray-900">Fragrance Profile</h3>
        
        <div>
          <label for="olfactiveFamily" class="block text-sm font-medium text-gray-700 mb-1">Olfactive Family</label>
          <select 
            id="olfactiveFamily" 
            name="olfactiveFamily"
            class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
          >
            <option value="">Select family</option>
            <% ['Oud', 'Rose', 'Musk', 'Amber', 'Woody', 'Floral', 'Oriental', 'Citrus', 'Fresh'].forEach(f => { %>
              <option value="<%= f %>" <%= product && product.olfactiveFamily === f ? 'selected' : '' %>><%= f %></option>
            <% }); %>
          </select>
        </div>
        
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label for="topNotes" class="block text-sm font-medium text-gray-700 mb-1">Top Notes</label>
            <input 
              type="text" 
              id="topNotes" 
              name="topNotes"
              value="<%= product && product.topNotes ? product.topNotes.join(', ') : '' %>"
              placeholder="Bergamot, Lemon"
              class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
            >
          </div>
          <div>
            <label for="middleNotes" class="block text-sm font-medium text-gray-700 mb-1">Heart Notes</label>
            <input 
              type="text" 
              id="middleNotes" 
              name="middleNotes"
              value="<%= product && product.middleNotes ? product.middleNotes.join(', ') : '' %>"
              placeholder="Rose, Jasmine"
              class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
            >
          </div>
          <div>
            <label for="baseNotes" class="block text-sm font-medium text-gray-700 mb-1">Base Notes</label>
            <input 
              type="text" 
              id="baseNotes" 
              name="baseNotes"
              value="<%= product && product.baseNotes ? product.baseNotes.join(', ') : '' %>"
              placeholder="Oud, Musk"
              class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
            >
          </div>
        </div>
      </div>
      
      <!-- Images -->
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="font-medium text-gray-900 mb-4">Images</h3>
        
        <div id="image-preview" class="grid grid-cols-4 gap-4 mb-4">
          <% if (product && product.images) { %>
            <% product.images.forEach((img, i) => { %>
              <div class="relative aspect-square bg-gray-100 rounded-md overflow-hidden">
                <img src="<%= img %>" alt="Product image <%= i + 1 %>" class="w-full h-full object-cover">
                <button type="button" onclick="removeImage(<%= i %>)" class="absolute top-1 right-1 w-6 h-6 bg-white rounded-full shadow flex items-center justify-center">
                  <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                </button>
              </div>
            <% }); %>
          <% } %>
        </div>
        
        <label class="block w-full p-8 border-2 border-dashed rounded-lg text-center cursor-pointer hover:border-emerald-500 transition-colors">
          <svg class="w-8 h-8 mx-auto text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <p class="mt-2 text-sm text-gray-600">Click to upload images</p>
          <input type="file" name="images" multiple accept="image/*" class="hidden">
        </label>
      </div>
      
      <!-- 3D Model -->
      <div class="bg-white rounded-lg shadow-sm p-6 space-y-4">
        <h3 class="font-medium text-gray-900">3D Model (Optional)</h3>
        
        <div>
          <label for="glbUrl" class="block text-sm font-medium text-gray-700 mb-1">GLB Model URL</label>
          <input 
            type="url" 
            id="glbUrl" 
            name="glbUrl"
            value="<%= product ? product.glbUrl : '' %>"
            placeholder="https://..."
            class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
          >
        </div>
        
        <div>
          <label for="usdzUrl" class="block text-sm font-medium text-gray-700 mb-1">USDZ Model URL (iOS AR)</label>
          <input 
            type="url" 
            id="usdzUrl" 
            name="usdzUrl"
            value="<%= product ? product.usdzUrl : '' %>"
            placeholder="https://..."
            class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
          >
        </div>
      </div>
    </div>
    
    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Status -->
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="font-medium text-gray-900 mb-4">Status</h3>
        <select 
          name="status"
          class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
        >
          <option value="active" <%= product && product.status === 'active' ? 'selected' : '' %>>Active</option>
          <option value="draft" <%= product && product.status === 'draft' ? 'selected' : '' %>>Draft</option>
        </select>
      </div>
      
      <!-- Pricing -->
      <div class="bg-white rounded-lg shadow-sm p-6 space-y-4">
        <h3 class="font-medium text-gray-900">Pricing</h3>
        
        <div>
          <label for="price" class="block text-sm font-medium text-gray-700 mb-1">Price</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">$</span>
            <input 
              type="number" 
              id="price" 
              name="price"
              value="<%= product ? product.price : '' %>"
              step="0.01"
              required
              class="w-full pl-8 pr-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
            >
          </div>
        </div>
        
        <div>
          <label for="compareAtPrice" class="block text-sm font-medium text-gray-700 mb-1">Compare at Price</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">$</span>
            <input 
              type="number" 
              id="compareAtPrice" 
              name="compareAtPrice"
              value="<%= product ? product.compareAtPrice : '' %>"
              step="0.01"
              class="w-full pl-8 pr-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
            >
          </div>
        </div>
      </div>
      
      <!-- Inventory -->
      <div class="bg-white rounded-lg shadow-sm p-6 space-y-4">
        <h3 class="font-medium text-gray-900">Inventory</h3>
        
        <div>
          <label for="inventory" class="block text-sm font-medium text-gray-700 mb-1">Quantity</label>
          <input 
            type="number" 
            id="inventory" 
            name="inventory"
            value="<%= product ? product.inventory : 0 %>"
            min="0"
            class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
          >
        </div>
        
        <div>
          <label for="sku" class="block text-sm font-medium text-gray-700 mb-1">SKU</label>
          <input 
            type="text" 
            id="sku" 
            name="sku"
            value="<%= product ? product.sku : '' %>"
            class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
          >
        </div>
        
        <label class="flex items-center gap-2">
          <input 
            type="checkbox" 
            name="trackInventory"
            <%= product && product.trackInventory ? 'checked' : '' %>
            class="rounded text-emerald-600 focus:ring-emerald-500"
          >
          <span class="text-sm text-gray-700">Track inventory</span>
        </label>
      </div>
      
      <!-- Collection -->
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="font-medium text-gray-900 mb-4">Collections</h3>
        <div class="space-y-2 max-h-48 overflow-y-auto">
          <% collections.forEach(c => { %>
            <label class="flex items-center gap-2">
              <input 
                type="checkbox" 
                name="collections"
                value="<%= c._id %>"
                <%= product && product.collections && product.collections.includes(c._id.toString()) ? 'checked' : '' %>
                class="rounded text-emerald-600 focus:ring-emerald-500"
              >
              <span class="text-sm text-gray-700"><%= c.title %></span>
            </label>
          <% }); %>
        </div>
      </div>
      
      <!-- Tags -->
      <div class="bg-white rounded-lg shadow-sm p-6">
        <h3 class="font-medium text-gray-900 mb-4">Tags</h3>
        <input 
          type="text" 
          name="tags"
          value="<%= product && product.tags ? product.tags.join(', ') : '' %>"
          placeholder="new, featured, sale"
          class="w-full px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
        >
        <p class="mt-1 text-xs text-gray-500">Separate tags with commas</p>
      </div>
    </div>
  </div>
  
  <!-- Actions -->
  <div class="flex items-center justify-end gap-4 border-t pt-6">
    <a href="/admin/products" class="px-6 py-2 border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">
      Cancel
    </a>
    <button type="submit" class="px-6 py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-medium rounded-md transition-colors">
      <%= product ? 'Save Changes' : 'Create Product' %>
    </button>
  </div>
</form>

<script>
// Auto-generate handle from title
document.getElementById('title').addEventListener('input', (e) => {
  const handleInput = document.getElementById('handle');
  if (!handleInput.value) {
    handleInput.value = e.target.value
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)/g, '');
  }
});
</script>
