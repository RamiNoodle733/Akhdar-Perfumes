<footer class="bg-emerald-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block">
          <img 
            src="/images/logo-white.png" 
            alt="<%= settings.siteName %>" 
            class="h-10 w-auto"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
          >
          <span class="hidden text-2xl font-bold">Akhdar</span>
        </a>
        <p class="mt-4 text-sm text-gray-300">
          Premium attar and oud roll-on perfume oils, handcrafted with the finest ingredients.
        </p>
        <!-- Social Links -->
        <div class="mt-6 flex space-x-4">
          <a href="#" class="text-gray-300 hover:text-white" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="#" class="text-gray-300 hover:text-white" aria-label="TikTok">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Shop -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider">Shop</h3>
        <ul class="mt-4 space-y-3">
          <li><a href="/products" class="text-sm text-gray-300 hover:text-white">All Products</a></li>
          <li><a href="/collections" class="text-sm text-gray-300 hover:text-white">Collections</a></li>
          <li><a href="/collections/new-arrivals" class="text-sm text-gray-300 hover:text-white">New Arrivals</a></li>
          <li><a href="/collections/best-sellers" class="text-sm text-gray-300 hover:text-white">Best Sellers</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider">Support</h3>
        <ul class="mt-4 space-y-3">
          <li><a href="/contact" class="text-sm text-gray-300 hover:text-white">Contact Us</a></li>
          <li><a href="/pages/shipping" class="text-sm text-gray-300 hover:text-white">Shipping Info</a></li>
          <li><a href="/pages/returns" class="text-sm text-gray-300 hover:text-white">Returns & Exchanges</a></li>
          <li><a href="/pages/faq" class="text-sm text-gray-300 hover:text-white">FAQ</a></li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider">Stay Connected</h3>
        <p class="mt-4 text-sm text-gray-300">Subscribe for exclusive offers and fragrance tips.</p>
        <form class="mt-4" action="/newsletter" method="POST">
          <div class="flex">
            <input 
              type="email" 
              name="email" 
              placeholder="Enter your email" 
              required
              class="flex-1 px-4 py-2 text-sm text-gray-900 bg-white rounded-l-md focus:outline-none focus:ring-2 focus:ring-emerald-500"
            >
            <button 
              type="submit" 
              class="px-4 py-2 text-sm font-medium bg-black text-white rounded-r-md hover:bg-gray-800 transition-colors"
            >
              Subscribe
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-emerald-800">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <p class="text-sm text-gray-400">
          &copy; <%= new Date().getFullYear() %> Akhdar Perfumes. All rights reserved.
        </p>
        <div class="flex space-x-6">
          <a href="/pages/privacy-policy" class="text-sm text-gray-400 hover:text-white">Privacy Policy</a>
          <a href="/pages/terms-of-service" class="text-sm text-gray-400 hover:text-white">Terms of Service</a>
          <a href="/pages/refund-policy" class="text-sm text-gray-400 hover:text-white">Refund Policy</a>
        </div>
      </div>
    </div>
  </div>
</footer>
