<header class="sticky top-0 z-40 bg-black text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Mobile Menu Button -->
      <button 
        type="button" 
        class="lg:hidden p-2 -ml-2"
        onclick="toggleMobileMenu()"
        aria-label="Open menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img 
          src="/images/logo-white.png" 
          alt="<%= settings.siteName %>" 
          class="h-8 lg:h-10 w-auto"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
        >
        <span class="hidden text-xl font-bold tracking-tight">Akhdar</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center space-x-8">
        <a href="/" class="text-sm font-medium hover:text-gray-300 transition-colors <%= currentPath === '/' ? 'text-white' : 'text-gray-300' %>">
          Home
        </a>
        <a href="/collections" class="text-sm font-medium hover:text-gray-300 transition-colors <%= currentPath.startsWith('/collections') ? 'text-white' : 'text-gray-300' %>">
          Collections
        </a>
        <a href="/products" class="text-sm font-medium hover:text-gray-300 transition-colors <%= currentPath.startsWith('/products') ? 'text-white' : 'text-gray-300' %>">
          Shop All
        </a>
        <a href="/pages/about" class="text-sm font-medium hover:text-gray-300 transition-colors">
          About
        </a>
        <a href="/contact" class="text-sm font-medium hover:text-gray-300 transition-colors <%= currentPath === '/contact' ? 'text-white' : 'text-gray-300' %>">
          Contact
        </a>
      </nav>

      <!-- Right Actions -->
      <div class="flex items-center space-x-4">
        <!-- Search -->
        <button 
          type="button" 
          class="p-2"
          onclick="openSearchModal()"
          aria-label="Search"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </button>

        <!-- Cart -->
        <button 
          type="button" 
          class="p-2 relative"
          onclick="openCartDrawer()"
          aria-label="Open cart"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          <% if (cart.itemCount > 0) { %>
            <span class="absolute -top-1 -right-1 bg-emerald-600 text-white text-xs w-5 h-5 flex items-center justify-center rounded-full" id="cart-count">
              <%= cart.itemCount %>
            </span>
          <% } %>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-black border-t border-gray-800">
    <div class="px-4 py-6 space-y-4">
      <a href="/" class="block text-lg font-medium hover:text-gray-300">Home</a>
      <a href="/collections" class="block text-lg font-medium hover:text-gray-300">Collections</a>
      <a href="/products" class="block text-lg font-medium hover:text-gray-300">Shop All</a>
      <a href="/pages/about" class="block text-lg font-medium hover:text-gray-300">About</a>
      <a href="/contact" class="block text-lg font-medium hover:text-gray-300">Contact</a>
    </div>
  </div>
</header>

<script>
function toggleMobileMenu() {
  const menu = document.getElementById('mobile-menu');
  menu.classList.toggle('hidden');
}
</script>
