<article class="product-card group">
  <a href="/products/<%= product.handle %>" class="block">
    <!-- Image -->
    <div class="relative aspect-square bg-gray-100 rounded-lg overflow-hidden mb-4">
      <% if (product.images && product.images.length > 0) { %>
        <img 
          src="<%= product.images[0] %>" 
          alt="<%= product.title %>" 
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        >
        <% if (product.images.length > 1) { %>
          <img 
            src="<%= product.images[1] %>" 
            alt="<%= product.title %>" 
            class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            loading="lazy"
          >
        <% } %>
      <% } else { %>
        <div class="w-full h-full flex items-center justify-center text-gray-400">
          <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
      <% } %>
      
      <!-- Badges -->
      <div class="absolute top-3 left-3 flex flex-col gap-2">
        <% if (product.tags && product.tags.includes('new')) { %>
          <span class="px-2 py-1 text-xs font-medium bg-emerald-600 text-white rounded">New</span>
        <% } %>
        <% if (product.compareAtPrice && product.compareAtPrice > product.price) { %>
          <span class="px-2 py-1 text-xs font-medium bg-red-600 text-white rounded">
            -<%= Math.round((1 - product.price / product.compareAtPrice) * 100) %>%
          </span>
        <% } %>
        <% if (!product.available) { %>
          <span class="px-2 py-1 text-xs font-medium bg-gray-800 text-white rounded">Sold Out</span>
        <% } %>
      </div>
      
      <!-- Quick Add -->
      <% if (product.available && (!product.variants || product.variants.length <= 1)) { %>
        <div class="absolute bottom-3 inset-x-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <button 
            type="button"
            onclick="event.preventDefault(); quickAddToCart('<%= product._id %>')"
            class="w-full py-2.5 text-sm font-medium bg-white/95 hover:bg-white text-gray-900 rounded-md transition-colors backdrop-blur-sm"
          >
            Quick Add
          </button>
        </div>
      <% } %>
    </div>
    
    <!-- Info -->
    <div class="space-y-1">
      <% if (product.vendor) { %>
        <p class="text-xs text-gray-500 uppercase tracking-wider"><%= product.vendor %></p>
      <% } %>
      <h3 class="text-sm font-medium text-gray-900 group-hover:text-emerald-600 transition-colors line-clamp-2">
        <%= product.title %>
      </h3>
      <div class="flex items-center gap-2">
        <span class="text-sm font-medium text-gray-900">$<%= product.price.toFixed(2) %></span>
        <% if (product.compareAtPrice && product.compareAtPrice > product.price) { %>
          <span class="text-sm text-gray-400 line-through">$<%= product.compareAtPrice.toFixed(2) %></span>
        <% } %>
      </div>
      <% if (product.olfactiveFamily) { %>
        <p class="text-xs text-gray-500"><%= product.olfactiveFamily %></p>
      <% } %>
    </div>
  </a>
</article>

<% if (typeof includeScript === 'undefined' || includeScript) { %>
<script>
async function quickAddToCart(productId) {
  try {
    const response = await fetch('/cart/add', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({ 
        productId: productId,
        quantity: 1 
      })
    });
    const data = await response.json();
    if (data.success) {
      // Update cart count
      const cartCount = document.getElementById('cart-count');
      if (cartCount) {
        cartCount.textContent = data.cart.itemCount;
        cartCount.classList.remove('hidden');
      }
      // Open cart drawer
      openCartDrawer();
    }
  } catch (error) {
    console.error('Failed to add to cart:', error);
  }
}
</script>
<% } %>
