{% doc %}
  @prompt
    A heading with an animated glowing effect
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-glow-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px;
    position: relative;
    display: inline-block;
    width: 100%;
  }

  .ai-glow-heading-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    color: {{ block.settings.text_color }};
    margin: 0;
    position: relative;
    z-index: 2;
    text-shadow: 
      0 0 {{ block.settings.glow_intensity }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_intensity | times: 2 }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_intensity | times: 3 }}px {{ block.settings.glow_color }};
    animation: ai-glow-pulse-{{ ai_gen_id }} {{ block.settings.animation_duration }}s ease-in-out infinite alternate;
  }

  @keyframes ai-glow-pulse-{{ ai_gen_id }} {
    0% {
      text-shadow: 
        0 0 {{ block.settings.glow_intensity }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 2 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 3 }}px {{ block.settings.glow_color }};
    }
    100% {
      text-shadow: 
        0 0 {{ block.settings.glow_intensity | times: 1.5 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 3 }}px {{ block.settings.glow_color }},
        0 0 {{ block.settings.glow_intensity | times: 4.5 }}px {{ block.settings.glow_color }};
    }
  }

  {% if block.settings.background_glow %}
    .ai-glow-heading-{{ ai_gen_id }}::before {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 120%;
      height: 120%;
      background: radial-gradient(
        ellipse at center,
        {{ block.settings.glow_color }}{{ block.settings.background_glow_opacity | divided_by: 100.0 | times: 255 | round | prepend: '0' | slice: -2 }},
        transparent 70%
      );
      border-radius: 50%;
      z-index: 1;
      animation: ai-background-glow-{{ ai_gen_id }} {{ block.settings.animation_duration }}s ease-in-out infinite alternate;
    }

    @keyframes ai-background-glow-{{ ai_gen_id }} {
      0% {
        opacity: 0.3;
        transform: translate(-50%, -50%) scale(1);
      }
      100% {
        opacity: 0.7;
        transform: translate(-50%, -50%) scale(1.1);
      }
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-glow-heading-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div
  class="ai-glow-heading-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% case block.settings.heading_tag %}
    {% when 'h1' %}
      <h1 class="ai-glow-heading-text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h1>
    {% when 'h2' %}
      <h2 class="ai-glow-heading-text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h2>
    {% when 'h3' %}
      <h3 class="ai-glow-heading-text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h3>
    {% when 'h4' %}
      <h4 class="ai-glow-heading-text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h4>
    {% when 'h5' %}
      <h5 class="ai-glow-heading-text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h5>
    {% when 'h6' %}
      <h6 class="ai-glow-heading-text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h6>
  {% endcase %}
</div>

{% schema %}
{
  "name": "Glowing heading",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Glowing Heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Font size",
      "default": 48
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Glow effect"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#00ff88"
    },
    {
      "type": "range",
      "id": "glow_intensity",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Glow intensity",
      "default": 20
    },
    {
      "type": "range",
      "id": "animation_duration",
      "min": 1,
      "max": 5,
      "step": 0.5,
      "unit": "s",
      "label": "Animation duration",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "background_glow",
      "label": "Background glow",
      "default": true
    },
    {
      "type": "range",
      "id": "background_glow_opacity",
      "min": 10,
      "max": 80,
      "step": 10,
      "unit": "%",
      "label": "Background glow opacity",
      "default": 30
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom margin",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Glowing heading"
    }
  ]
}
{% endschema %}